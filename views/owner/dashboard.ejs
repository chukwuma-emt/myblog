<div class="admin-page-header">
  <h1>Owner Dashboard</h1>
  <a href="/dashboard" class="btn-admin" style="background:var(--surface);color:var(--text);border:1px solid var(--border);">← Posts</a>
</div>

<!-- REGISTER NEW USER -->
<div class="admin-card" style="margin-bottom:24px;">
  <p class="form-section" style="margin-bottom:20px;">Register New Admin User</p>

  <form action="/owner/register" method="POST" class="admin-form">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div class="form-field">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Enter username" required>
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter password" required>
      </div>
    </div>
    <div>
      <button type="submit" class="btn-admin">Register User</button>
    </div>
  </form>
</div>

<!-- SUBSCRIBERS -->
<div class="admin-page-header" style="margin-bottom:16px;">
  <h1 style="font-size:1.1rem;">Newsletter Subscribers (<%= subscribers.length %>)</h1>
</div>

<div class="admin-card" style="margin-bottom:32px;">
  <% if (subscribers.length === 0) { %>
    <p style="color:var(--muted);font-size:0.9rem;">No subscribers yet.</p>
  <% } else { %>
    <div class="subscriber-list">
      <% subscribers.forEach(sub => { %>
        <div class="subscriber-item">
          <span class="subscriber-email">📧 <%= sub.email %></span>
          <span style="color:var(--muted);font-size:0.8rem;">
            <%= new Date(sub.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
          </span>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- USER LIST -->
<div class="admin-page-header" style="margin-bottom:16px;">
  <h1 style="font-size:1.1rem;">Admin Users (<%= users.length %>)</h1>
</div>

<div class="user-list">
  <% if (users.length === 0) { %>
    <p style="color:var(--muted);font-size:0.9rem;">No users registered yet.</p>
  <% } %>

  <% users.forEach(user => { %>
    <div class="user-card">
      <div class="user-info">
        <strong>
          <%= user.username %>
          <span class="badge <%= user.role === 'restricted' ? 'restricted' : 'active' %>">
            <%= user.role %>
          </span>
        </strong>
        <small>Registered user</small>
      </div>

      <div class="user-actions">
        <% if (user.role !== 'restricted') { %>
          <form action="/owner/restrict/<%= user._id %>" method="POST" style="margin:0">
            <button type="submit" class="btn-admin sm warning">Restrict</button>
          </form>
        <% } else { %>
          <form action="/owner/unrestrict/<%= user._id %>" method="POST" style="margin:0">
            <button type="submit" class="btn-admin sm success">Unrestrict</button>
          </form>
        <% } %>

        <form action="/owner/delete/<%= user._id %>" method="POST"
              style="margin:0"
              onsubmit="return confirm('Delete user <%= user.username %>?')">
          <button type="submit" class="btn-admin sm danger">Delete</button>
        </form>
      </div>
    </div>
  <% }) %>
</div>
