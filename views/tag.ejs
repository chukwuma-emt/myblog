<section class="articles">
  <div class="tag-page-header">
    <a href="/" class="back-link">← All Posts</a>
    <h1>Posts tagged <span class="tag-highlight">#<%= tag %></span></h1>
    <p style="color:var(--muted);font-size:0.9rem;"><%= posts.length %> post<%= posts.length !== 1 ? 's' : '' %> found</p>
  </div>

  <% if (posts.length === 0) { %>
    <p style="color:var(--muted);margin-top:24px;">No posts with this tag yet.</p>
  <% } %>

  <div class="articles-cards">
    <% posts.forEach(post => { %>
      <article class="card">
        <div class="media-box">
          <% if (post.mediaType === 'image' && post.mediaFile) { %>
            <img src="/uploads/images/<%= post.mediaFile %>" alt="<%= post.title %>" loading="lazy">
          <% } else { %>
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#1d4ed8,#0284c7);display:flex;align-items:center;justify-content:center;color:white;font-size:2.5rem;">📝</div>
          <% } %>
        </div>
        <div class="card-content">
          <h2 class="post-title"><%= post.title %></h2>
          <div class="tag-list">
            <% (post.tags || []).forEach(t => { %>
              <a href="/tag/<%= t %>" class="tag <%= t === tag ? 'tag-active' : '' %>">#<%= t %></a>
            <% }) %>
          </div>
          <div class="card-footer">
            <span class="article-list_date">
              <%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </span>
          </div>
          <div class="open-link">
            <a href="/post/<%= post.slug %>">Read article →</a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>
