<div class="admin-page-header">
  <h1>Edit Post</h1>
  <div style="display:flex;gap:8px;">
    <a href="/dashboard" class="btn-admin" style="background:var(--surface);color:var(--text);border:1px solid var(--border);">← Back</a>
    <form action="/delete-post/<%= data._id %>?_method=DELETE"
          method="POST"
          style="margin:0"
          onsubmit="return confirm('Permanently delete this post?')">
      <button type="submit" class="btn-admin danger">Delete Post</button>
    </form>
  </div>
</div>

<div class="admin-card">

  <div class="markdown-hint" style="margin-bottom:24px;">
    <strong>Markdown supported:</strong> &nbsp;
    <code># Heading</code> &nbsp;
    <code>## Subheading</code> &nbsp;
    <code>**bold**</code> &nbsp;
    <code>* list item</code> &nbsp;
    <code>`code`</code>
  </div>

  <form action="/edit-post/<%= data._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="admin-form">

    <p class="form-section">Post Content</p>

    <div class="form-field">
      <label for="title">Post Title *</label>
      <input type="text" id="title" name="title" value="<%= data.title %>" required>
    </div>

    <div class="form-field">
      <label for="slug">URL Slug</label>
      <input type="text" id="slug" name="slug" value="<%= data.slug %>">
    </div>

    <div class="form-field">
      <label for="category">Category</label>
      <select id="category" name="category">
        <option value="nodejs"      <%= data.category === 'nodejs'      ? 'selected' : '' %>>Node.js</option>
        <option value="networking"  <%= data.category === 'networking'  ? 'selected' : '' %>>Networking</option>
        <option value="business"    <%= data.category === 'business'    ? 'selected' : '' %>>Business Tech</option>
        <option value="tutorials"   <%= data.category === 'tutorials'   ? 'selected' : '' %>>Tutorials</option>
      </select>
    </div>

    <div class="form-field">
      <label for="excerpt">Excerpt</label>
      <textarea id="excerpt" name="excerpt" rows="3"><%= data.excerpt %></textarea>
    </div>

    <div class="form-field">
      <label for="body">Content (Markdown) *</label>
      <textarea id="body" name="body" rows="16" required><%= data.body %></textarea>
    </div>

    <div class="form-field">
      <label for="tags">Tags</label>
      <input type="text" id="tags" name="tags" value="<%= data.tags ? data.tags.join(', ') : '' %>">
      <small>Separate tags with commas</small>
    </div>

    <div class="form-field">
      <label for="media">Replace Media</label>
      <input type="file" id="media" name="media" accept="image/*,video/*,audio/*">
    </div>

    <% if (data.mediaFile) { %>
      <div class="media-preview">
        <p>Current Media</p>
        <% if (data.mediaType === 'image') { %>
          <img src="/uploads/images/<%= data.mediaFile %>" alt="Current media">
        <% } else if (data.mediaType === 'video') { %>
          <video controls><source src="/uploads/videos/<%= data.mediaFile %>"></video>
        <% } else if (data.mediaType === 'audio') { %>
          <audio controls><source src="/uploads/audio/<%= data.mediaFile %>"></audio>
        <% } %>
      </div>
    <% } %>

    <p class="form-section">SEO</p>

    <div class="form-field">
      <label for="seoTitle">SEO Title</label>
      <input type="text" id="seoTitle" name="seoTitle" value="<%= data.seoTitle || '' %>">
    </div>

    <div class="form-field">
      <label for="metaDescription">Meta Description</label>
      <textarea id="metaDescription" name="metaDescription" rows="3"><%= data.metaDescription || '' %></textarea>
    </div>

    <button type="submit" class="btn-admin" style="width:100%;justify-content:center;padding:12px;font-size:0.95rem;">
      💾 Update Post
    </button>

  </form>
</div>
