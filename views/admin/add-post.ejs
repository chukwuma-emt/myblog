<div class="admin-page-header">
  <h1>Create New Post</h1>
  <a href="/dashboard" class="btn-admin" style="background:var(--surface);color:var(--text);border:1px solid var(--border);">← Back</a>
</div>

<div class="admin-card">

  <div class="markdown-hint" style="margin-bottom:24px;">
    <strong>Markdown supported:</strong> &nbsp;
    <code># Heading</code> &nbsp;
    <code>## Subheading</code> &nbsp;
    <code>**bold**</code> &nbsp;
    <code>* list item</code> &nbsp;
    <code>`code`</code>
  </div>

  <form action="/add-post" method="POST" enctype="multipart/form-data" class="admin-form">

    <p class="form-section">Post Content</p>

    <div class="form-field">
      <label for="title">Post Title *</label>
      <input type="text" id="title" name="title" placeholder="e.g. How to Build a POS System with Node.js" required>
    </div>

    <div class="form-field">
      <label for="slug">URL Slug</label>
      <input type="text" id="slug" name="slug" placeholder="e.g. build-pos-system-nodejs">
      <small>Auto-generated from title if left empty</small>
    </div>

    <div class="form-field">
      <label for="category">Category</label>
      <select id="category" name="category">
        <option value="nodejs">Node.js</option>
        <option value="networking">Networking</option>
        <option value="business">Business Tech</option>
        <option value="tutorials">Tutorials</option>
      </select>
    </div>

    <div class="form-field">
      <label for="excerpt">Excerpt</label>
      <textarea id="excerpt" name="excerpt" rows="3" placeholder="Short summary shown on the homepage"></textarea>
    </div>

    <div class="form-field">
      <label for="body">Content (Markdown) *</label>
      <textarea id="body" name="body" rows="16" placeholder="Write your article using Markdown..." required></textarea>
    </div>

    <div class="form-field">
      <label for="tags">Tags</label>
      <input type="text" id="tags" name="tags" placeholder="e.g. nodejs, mongodb, express">
      <small>Separate tags with commas</small>
    </div>

    <div class="form-field">
      <label for="media">Upload Media</label>
      <input type="file" id="media" name="media" accept="image/*,video/*,audio/*">
      <small>Supports images, videos, and audio</small>
    </div>

    <p class="form-section">SEO</p>

    <div class="form-field">
      <label for="seoTitle">SEO Title</label>
      <input type="text" id="seoTitle" name="seoTitle" placeholder="Optimized title for Google (leave empty to use post title)">
    </div>

    <div class="form-field">
      <label for="metaDescription">Meta Description</label>
      <textarea id="metaDescription" name="metaDescription" rows="3" placeholder="160-character description for Google search results"></textarea>
    </div>

    <button type="submit" class="btn-admin" style="width:100%;justify-content:center;padding:12px;font-size:0.95rem;">
      🚀 Publish Post
    </button>

  </form>
</div>
