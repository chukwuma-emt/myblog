<div class="admin-page-header">
  <h1>Posts</h1>
  <a href="/add-post" class="btn-admin">+ New Post</a>
</div>

<div class="post-list">
  <% if (data.length === 0) { %>
    <p style="color:var(--muted);font-size:0.9rem;">No posts yet. <a href="/add-post">Create your first post →</a></p>
  <% } %>

  <% data.forEach(post => { %>
    <div class="post-item">
      <a href="/post/<%= post.slug %>" class="post-item-title" target="_blank">
        <%= post.title %>
      </a>
      <div class="post-item-controls">
        <a href="/edit-post/<%= post._id %>" class="btn-admin sm success">Edit</a>
        <form action="/delete-post/<%= post._id %>?_method=DELETE"
              method="POST"
              style="margin:0"
              onsubmit="return confirm('Delete this post?')">
          <button type="submit" class="btn-admin sm danger">Delete</button>
        </form>
      </div>
    </div>
  <% }) %>
</div>
