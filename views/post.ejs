<div class="post-page">

  <!-- BACK LINK -->
  <a href="/" class="back-link">← Back to Blog</a>

  <!-- MEDIA -->
  <% if (data.mediaType === 'image') { %>
    <div class="post-media">
      <img src="/uploads/images/<%= data.mediaFile %>" alt="<%= data.title %>" loading="lazy">
    </div>
  <% } else if (data.mediaType === 'video') { %>
    <div class="post-media">
      <video controls>
        <source src="/uploads/videos/<%= data.mediaFile %>" type="video/mp4">
      </video>
    </div>
  <% } else if (data.mediaType === 'audio') { %>
    <div class="post-media">
      <audio controls>
        <source src="/uploads/audio/<%= data.mediaFile %>" type="audio/mpeg">
      </audio>
    </div>
  <% } %>

  <!-- POST HEADER -->
  <div class="post-header">
    <h1><%= data.title %></h1>
    <div class="post-meta-bar">
      <span class="meta-item">
        📅 <%= new Date(data.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
      </span>
      <span class="meta-item">👁 <%= data.views || 0 %> views</span>
      <span class="meta-item">
        ❤️ <span id="likeCount"><%= data.likes || 0 %></span> likes
      </span>
    </div>
  </div>

  <!-- LIKE SECTION -->
  <div class="like-section">
    <span>Found this helpful?</span>
    <button id="likeBtn" data-postid="<%= data._id %>">❤️ Like this post</button>
  </div>

  <!-- ARTICLE BODY -->
  <article class="article">
    <%- data.body %>
  </article>

  <!-- COMMENTS -->
  <section class="comments-section">
    <h3>💬 Comments (<%= comments.length %>)</h3>

    <div id="commentList">
      <% if (comments.length === 0) { %>
        <p style="color:var(--muted);font-size:0.9rem;margin-bottom:24px;">No comments yet. Be the first!</p>
      <% } else { %>
        <% comments.forEach(comment => { %>
          <div class="comment">
            <div class="comment-avatar"><%= comment.username.charAt(0).toUpperCase() %></div>
            <div class="comment-body">
              <strong><%= comment.username %></strong>
              <p><%= comment.text %></p>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <p class="comment-form-title">Leave a comment</p>
    <form id="commentForm">
      <input type="hidden" id="postId" name="postId" value="<%= data._id %>">
      <input type="text" id="username" name="username" placeholder="Your name" required>
      <textarea id="commentText" name="text" placeholder="Write your comment..." required></textarea>
      <button type="submit">Post Comment</button>
    </form>
  </section>

</div>

<script src="/js/post-actions.js"></script>
