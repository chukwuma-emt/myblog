<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <h1>Insights for Builders</h1>
    <p>
      Tutorials, deep dives, and real-world projects covering Node.js,
      MongoDB, web development, and modern software design.
    </p>
  </div>
</section>

<!-- ARTICLES -->
<section class="articles">
  <h2 class="articles__heading">Latest Posts</h2>
  <div class="heading-accent"></div>

  <% if (data.length === 0) { %>
    <p style="color:var(--muted);font-size:0.95rem;">No posts yet — check back soon.</p>
  <% } %>

  <div class="articles-cards">
    <% data.forEach(post => { %>
      <article class="card">

        <!-- MEDIA -->
        <div class="media-box">
          <% if (post.mediaType === 'image') { %>
            <img src="/uploads/images/<%= post.mediaFile %>" alt="<%= post.title %>" loading="lazy">
          <% } else if (post.mediaType === 'video') { %>
            <video controls playsinline>
              <source src="/uploads/videos/<%= post.mediaFile %>">
            </video>
          <% } else if (post.mediaType === 'audio') { %>
            <audio controls>
              <source src="/uploads/audio/<%= post.mediaFile %>">
            </audio>
          <% } else { %>
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#1d4ed8,#0284c7);display:flex;align-items:center;justify-content:center;color:white;font-size:2.5rem;">📝</div>
          <% } %>
        </div>

        <!-- CARD BODY -->
        <div class="card-content" data-expand>
          <h2 class="post-title"><%= post.title %></h2>

          <p class="excerpt">
            <%= post.body.replace(/[#_*`>\[\]\-!]/g, '').substring(0, 110) %>...
          </p>

          <!-- EXPANDED CONTENT -->
          <div class="full-content">
            <button class="close-btn">✕ Close</button>
            <div class="full-body"><%- post.bodyHTML %></div>
          </div>

          <!-- META ROW -->
          <div class="card-footer">
            <span class="article-list_date">
              <%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </span>
            <div class="post-meta">
              <span>👁 <%= post.views || 0 %></span>
              <span>❤️ <%= post.likes || 0 %></span>
            </div>
          </div>

          <div class="open-link">
            <a href="/post/<%= post.slug %>">Read full article →</a>
          </div>
        </div>

      </article>
    <% }) %>
  </div>

  <% if (nextPage !== null) { %>
    <a href="/?page=<%= nextPage %>" class="pagination">← Older Posts</a>
  <% } %>

</section>

<script src="/js/main.js" defer></script>
