<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Welcome | Blog by Chukwuma</title>
  <link rel="stylesheet" href="/css/styles.css">

  <style>
    /* Make card clickable */
    .card-content {
      cursor: pointer;
    }

    /* Hidden full content */
    .full-content {
      display: none;
      padding: 0 15px 10px;
      font-size: 0.9rem;
      color: #444;
      line-height: 1.6;
    }
  </style>
</head>

<body>

<div class="page">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <h1>Welcome to My Blog</h1>
      <p>
        Explore insightful articles, videos, and audio content on web development,
        tech trends, and personal experiences.
      </p>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="articles">
    <h2 class="articles__heading">Latest Posts</h2>

    <% if (data.length === 0) { %>
      <p>No posts available yet.</p>
    <% } %>

    <div class="articles-cards">
      <% data.forEach(post => { %>
        <div class="card">

          <!-- MEDIA (not clickable for expand) -->
          <div class="media-box">
            <% if (post.mediaType === 'image') { %>
              <img src="/uploads/images/<%= post.mediaFile %>" alt="<%= post.title %>">
            <% } else if (post.mediaType === 'video') { %>
              <video controls playsinline>
                <source src="/uploads/videos/<%= post.mediaFile %>">
              </video>
            <% } else if (post.mediaType === 'audio') { %>
              <audio controls>
                <source src="/uploads/audio/<%= post.mediaFile %>">
              </audio>
            <% } else { %>
              <img src="/img/default-post.jpg" alt="default image">
            <% } %>
          </div>

          <!-- CONTENT (clickable area) -->
          <div class="card-content">

            <h2 style="padding: 10px 15px 0;"><%= post.title %></h2>

            <!-- SHORT TEXT -->
            <p class="excerpt">
              <%= post.body.replace(/[#_*`>-]/g, '').substring(0, 80) %>...
            </p>

            <!-- FULL CONTENT (HTML) -->
            <div class="full-content">
              <%- post.bodyHTML %>
            </div>

            <!-- META -->
            <p class="article-list_date" style="padding: 0 15px;">
              <%= new Date(post.createdAt).toDateString() %>
            </p>

            <div class="post-meta">
              <small>👁️ <%= post.views || 0 %></small>
              <small>❤️ <%= post.likes || 0 %></small>
            </div>

            <!-- OPTIONAL FULL PAGE LINK -->
            <p style="padding: 0 15px 15px;">
              <a href="/post/<%= post.slug %>">Open full page →</a>
            </p>

          </div>

        </div>
      <% }) %>
    </div>

    <!-- PAGINATION -->
    <% if (nextPage !== null) { %>
      <a href="/?page=<%= nextPage %>" class="pagination">
        ← View Older Posts
      </a>
    <% } %>

  </section>

</div>

<!-- JS -->
<script src="/js/main.js" defer></script>

</body>
</html>